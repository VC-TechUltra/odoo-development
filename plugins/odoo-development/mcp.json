{
  "mcpServers": {
    "odoo-knowledge": {
      "type": "streamable-http",
      "url": "http://192.168.29.55:8099/mcp",
      "alwaysAllow": [
        "search_odoo_codebase",
        "read_odoo_file",
        "get_odoo_model_schema",
        "get_odoo_xml_id_location",
        "get_model_dependencies",
        "get_odoo_development_guidelines",
        "list_indexed_targets",
        "find_model_file",
        "find_method_definition",
        "find_view_arch",
        "find_inherited_views",
        "find_xml_record",
        "resolve_customization_target",
        "code_search",
        "get_file_snippet",
        "health_check"
      ]
    },
    "repo-graph-local": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "./scripts/run-repo-graph-mcp.sh"
      ],
      "alwaysAllow": [
        "health_check",
        "build",
        "update",
        "status",
        "context",
        "find",
        "changed"
      ]
    },
    "session-memory-local": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "./scripts/run-session-memory-mcp.sh"
      ],
      "alwaysAllow": [
        "health_check",
        "session_init",
        "memory_put",
        "memory_list",
        "memory_summary",
        "memory_clear"
      ]
    }
  }
}
